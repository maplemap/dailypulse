{
  "name": "dailypulse",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@grammyjs/conversations": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.34.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "prettier": "^3.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1"
  }
}
